<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <style>
    {% include "css/base.css" %}
    {% include "css/layout.css" %}
    {% include "css/tabs.css" %}
    {% include "css/content.css" %}
    {% include "css/a11y.css" %}
    </style>
    {% include "partials/tab-js.njk" %}
</head>
<body>
    {% include "partials/skip-link.njk" %}
    <div class="container">
        {% include "partials/header.njk" %}
        <main id="main-content">
            {% if tabs %}
            <nav class="nav-buttons" role="tablist" aria-label="Course content">
                {% for tab in tabs %}
                <button type="button"
                        class="nav-button{% if loop.first %} active{% endif %}"
                        id="tab-{{ tab.id }}"
                        role="tab"
                        aria-selected="{{ 'true' if loop.first else 'false' }}"
                        aria-controls="{{ tab.id }}"
                        {% if not loop.first %}tabindex="-1"{% endif %}>{{ tab.label }}</button>
                {% endfor %}
            </nav>
            {% endif %}

            {{ content | safe }}
        </main>
        {% include "partials/footer.njk" %}
    </div>
</body>
</html>